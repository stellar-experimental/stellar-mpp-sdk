{
  "name": "stellar-mpp-sdk",
  "version": "0.1.0",
  "description": "Stellar blockchain payment method for the Machine Payments Protocol (MPP)",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./channel": {
      "types": "./dist/channel/index.d.ts",
      "default": "./dist/channel/index.js"
    },
    "./channel/client": {
      "types": "./dist/channel/client/index.d.ts",
      "default": "./dist/channel/client/index.js"
    },
    "./channel/server": {
      "types": "./dist/channel/server/index.d.ts",
      "default": "./dist/channel/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "tsc",
    "build": "tsc",
    "check:types": "tsc --noEmit",
    "test": "vitest",
    "demo:server": "tsx examples/server.ts",
    "demo:client": "tsx examples/client.ts",
    "demo:channel-server": "tsx examples/channel-server.ts",
    "demo:channel-client": "tsx examples/channel-client.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "@stellar/stellar-sdk": ">=14.0.0",
    "mppx": ">=0.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stellar/stellar-sdk": "^14.6.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "mppx": "^0.4.7",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.1.0"
  },
  "license": "MIT",
  "dependencies": {
    "zod": "4.3.6"
  }
}
